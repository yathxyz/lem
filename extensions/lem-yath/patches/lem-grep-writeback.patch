+(defun grep-common-prefix-length (first second)
+  (let ((limit (min (length first) (length second)))
+        (count 0))
+    (loop :while (< count limit)
+          :while (char= (char first count) (char second count))
+          :do (incf count))
+    count))
+
+(defun grep-common-suffix-length (first second prefix-length)
+  (let ((first-length (length first))
+        (second-length (length second))
+        (count 0))
+    (loop :while (< count (- (min first-length second-length)
+                             prefix-length))
+          :while (char= (char first (- first-length count 1))
+                        (char second (- second-length count 1)))
+          :do (incf count))
+    count))
+
+(defun replace-grep-source-line (point replacement)
+  (with-point ((start point)
+               (end point))
+    (line-start start)
+    (line-end end)
+    (let ((original (points-to-string start end)))
+      (unless (string= original replacement)
+        (let* ((prefix-length
+                 (grep-common-prefix-length original replacement))
+               (suffix-length
+                 (grep-common-suffix-length
+                  original replacement prefix-length))
+               (replacement-end (- (length replacement) suffix-length)))
+          (character-offset start prefix-length)
+          (character-offset end (- suffix-length))
+          (buffer-undo-boundary (point-buffer start))
+          (delete-between-points start end)
+          (insert-string start
+                         (subseq replacement prefix-length replacement-end))
+          (buffer-undo-boundary (point-buffer start)))))))
+
 (defun change-grep-buffer (start end old-len)
   (declare (ignore end old-len))
