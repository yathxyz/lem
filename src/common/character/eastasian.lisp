    `(let ((,g-code ,code))
       (declare (optimize (speed 3) (safety 0) (debug 0))
                (fixnum ,g-code ,code))
       ,(gen-binary-search-function *eastasian-full* g-code))))

(defun eastasian-code-p (code)
