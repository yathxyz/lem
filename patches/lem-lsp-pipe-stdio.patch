+               (unless (member (workspace-state workspace)
+                               '(:stopping :disposed))
+                 (cond
+                   ((string= kind "begin")
+                    (workspace-progress-begin workspace token value))
+                   ((string= kind "report")
+                    (workspace-progress-report workspace token value))
+                   ((string= kind "end")
+                    (workspace-progress-end workspace token)))))))))))
+  +null+)
