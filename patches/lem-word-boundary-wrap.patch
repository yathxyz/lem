+(defun word-wrappable-objects-string (objects)
+  "Return the displayed text represented by OBJECTS, or NIL when an object
+cannot safely participate in character-based word wrapping."
+  (block invalid
+    (with-output-to-string (stream)
+      (dolist (object objects)
+        (cond ((typep object 'line-end-object)
+               (return-from invalid nil))
+              ((typep object 'text-object)
+               (write-string (text-object-string object) stream))
+              ((typep object '(or void-object
+                                  eol-cursor-object
+                                  extend-to-eol-object)))
+              (t
+               (return-from invalid nil)))))))
+
+(defun word-boundary-view-width (objects view-width buffer)
+  "Reduce VIEW-WIDTH so the physical row ends at the same word boundary used
+by virtual-line navigation.  The ordinary width splitter remains the fallback
+for long words and drawing objects without a text mapping."
+  (unless (variable-value 'line-wrap-at-word-boundary :default buffer)
+    (return-from word-boundary-view-width view-width))
+  (let* ((character-width (lem-if:get-char-width (implementation)))
+         (view-columns (floor view-width character-width)))
+    (when (<= view-columns 1)
+      (return-from word-boundary-view-width view-width))
+    (alexandria:when-let ((string (word-wrappable-objects-string objects)))
+      (multiple-value-bind (boundary word-boundary-p)
+          (wrapping-line-break-index
+           string
+           (1- view-columns)
+           :tab-size (variable-value 'tab-width :default buffer)
+           :word-boundary-p t)
+        (when (and boundary word-boundary-p)
+          (let* ((content-columns
+                   (string-width string
+                                 :end boundary
+                                 :tab-size (variable-value 'tab-width
+                                                           :default buffer)))
+                 (word-view-width
+                   (* (1+ content-columns) character-width)))
+            (min view-width word-view-width)))))))
+
